{
  "name": "pr-flow",
  "version": "1.1.1",
  "description": "Governance skill para fluxo de Pull Requests — CI obrigatorio, labels, branch protection, preflight git-state, alerta de acumulo de PRs. Triggering otimizado.",
  "author": "Ian Vilhena <ianvilhena99@gmail.com>",
  "artifact": "pr-flow.skill",
  "artifact_sha256": "bfab5ad0c8f43d25724063815a16a80b5cd4a83095950f0da571584016fb90c3",
  "install_target": "~/.claude/skills/pr-flow",
  "required_tools": [
    "gh",
    "python3",
    "tar",
    "git"
  ],
  "optional_dependencies": [
    "orbit-engine (localhost:9100) — rastreabilidade fail-closed"
  ],
  "entrypoints": {
    "check": "scripts/check.sh",
    "apply": "scripts/apply.sh",
    "preflight-commit": "scripts/preflight-commit.sh"
  },
  "limits": {
    "max_lines_for_small_pr": 200,
    "pr_accumulation_warn_threshold": 5
  }
}
